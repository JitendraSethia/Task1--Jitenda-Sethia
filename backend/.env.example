# ------------------------------------------------------------------
# Groq API — create a free token at https://console.groq.com/keys
# ------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# NOTE: the assignment named `gemma2-9b-it`, but Groq has decommissioned it.
# We use currently-supported Groq models (see https://console.groq.com/docs/models).
# Primary (fast) model for form summarize/extraction
GROQ_MODEL=llama-3.1-8b-instant
# Model used for the LangGraph agent (tool-calling) + insights / next-best-action
GROQ_MODEL_REASONING=llama-3.3-70b-versatile
# Auto-retry count for transient 429 rate-limit errors (backoff honors Retry-After).
GROQ_MAX_RETRIES=5

# ------------------------------------------------------------------
# Database
# Default: SQLite (zero-config, runs immediately).
# For PostgreSQL (assignment preference) install psycopg and use e.g.:
#   DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/hcp_crm
# ------------------------------------------------------------------
DATABASE_URL=sqlite:///./hcp_crm.db

# CORS origin of the React dev server
FRONTEND_ORIGIN=http://localhost:5173
